<Window x:Class="LocalCrypto.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="localCrypto" Height="820" Width="1220" MinHeight="720" MinWidth="1040"
        Background="#F6F4EF" WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI" />
        </Style>
        <Style TargetType="Button">
            <Setter Property="FontFamily" Value="Segoe UI" />
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="Margin" Value="0,8,8,0" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Margin" Value="0,4,12,10" />
            <Setter Property="Padding" Value="8,6" />
            <Setter Property="MinWidth" Value="160" />
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Margin" Value="0,4,12,10" />
            <Setter Property="Padding" Value="8,6" />
            <Setter Property="MinWidth" Value="160" />
        </Style>
        <Style x:Key="Panel" TargetType="Border">
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderBrush" Value="#DCD7CC" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Padding" Value="18" />
            <Setter Property="Margin" Value="0,0,0,14" />
        </Style>
        <Style x:Key="DarkGridHeader" TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#111827" />
            <Setter Property="Foreground" Value="#CBD5E1" />
            <Setter Property="BorderBrush" Value="#263244" />
            <Setter Property="Padding" Value="8,6" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
        <Style x:Key="DarkGridCell" TargetType="DataGridCell">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="#E2E8F0" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="6,4" />
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="230" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#1F2933" Padding="22">
            <DockPanel LastChildFill="True">
                <StackPanel DockPanel.Dock="Top">
                    <TextBlock Text="localCrypto" Foreground="White" FontSize="24" FontWeight="SemiBold" />
                    <TextBlock Text="Windows ledger-first" Foreground="#B8C2CC" Margin="0,4,0,28" />
                    <TextBlock Text="V0.1.2 WPF" Foreground="#D7B46A" FontWeight="SemiBold" />
                    <TextBlock Text="Sans web, sans localhost" Foreground="#B8C2CC" Margin="0,4,0,28" />
                    <Button Content="Tableau de bord" Tag="Dashboard" Click="NavigateSection_Click" Background="#2F3A49" Foreground="White" BorderThickness="0" HorizontalContentAlignment="Left" />
                    <Button Content="Actifs" Tag="Positions" Click="NavigateSection_Click" Background="#2F3A49" Foreground="White" BorderThickness="0" HorizontalContentAlignment="Left" />
                    <Button Content="Imports" Tag="Imports" Click="NavigateSection_Click" Background="#2F3A49" Foreground="White" BorderThickness="0" HorizontalContentAlignment="Left" />
                    <Button Content="Donnees" Tag="Data" Click="NavigateSection_Click" Background="#2F3A49" Foreground="White" BorderThickness="0" HorizontalContentAlignment="Left" />
                </StackPanel>

                <StackPanel DockPanel.Dock="Bottom">
                    <TextBlock Text="Source de verite" Foreground="#B8C2CC" />
                    <TextBlock x:Name="DatabasePathText" TextWrapping="Wrap" Foreground="White" Margin="0,6,0,0" />
                </StackPanel>
            </DockPanel>
        </Border>

        <ScrollViewer x:Name="MainScrollViewer" Grid.Column="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="26">
                <TextBlock x:Name="DashboardAnchor" Text="Portefeuille" FontSize="30" FontWeight="SemiBold" Foreground="#17212B" />
                <TextBlock Text="Les positions sont reconstruites depuis les transactions SQLite locales." Foreground="#52606D" Margin="0,4,0,20" />

                <UniformGrid Columns="5" Margin="0,0,0,14">
                    <Border Style="{StaticResource Panel}" Margin="0,0,10,0">
                        <StackPanel>
                            <TextBlock Text="Portefeuille suivi" Foreground="#52606D" />
                            <TextBlock x:Name="TrackedBalanceText" FontSize="24" FontWeight="SemiBold" />
                            <TextBlock Text="hors prix live" Foreground="#7B8794" FontSize="11" />
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource Panel}" Margin="0,0,10,0">
                        <StackPanel>
                            <TextBlock Text="Investi" Foreground="#52606D" />
                            <TextBlock x:Name="InvestedText" FontSize="24" FontWeight="SemiBold" />
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource Panel}" Margin="0,0,10,0">
                        <StackPanel>
                            <TextBlock Text="PnL realise" Foreground="#52606D" />
                            <TextBlock x:Name="RealizedPnlText" FontSize="24" FontWeight="SemiBold" />
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource Panel}" Margin="0,0,10,0">
                        <StackPanel>
                            <TextBlock Text="Frais suivis" Foreground="#52606D" />
                            <TextBlock x:Name="FeesText" FontSize="24" FontWeight="SemiBold" />
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource Panel}">
                        <StackPanel>
                            <TextBlock Text="Confiance" Foreground="#52606D" />
                            <TextBlock x:Name="DataConfidenceText" FontSize="24" FontWeight="SemiBold" />
                            <TextBlock x:Name="DataConfidenceHintText" Foreground="#7B8794" FontSize="11" TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>
                </UniformGrid>

                <Border x:Name="PositionsAnchor" Style="{StaticResource Panel}">
                    <StackPanel>
                        <TextBlock Text="Positions" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,12" />
                        <DataGrid x:Name="PositionsGrid" AutoGenerateColumns="False" IsReadOnly="True" MinHeight="130" SelectionChanged="PositionsGrid_SelectionChanged">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Actif" Binding="{Binding Symbol}" Width="*" />
                                <DataGridTextColumn Header="Quantite" Binding="{Binding Quantity}" Width="*" />
                                <DataGridTextColumn Header="Prix moyen" Binding="{Binding AverageCost}" Width="*" />
                                <DataGridTextColumn Header="Cout investi" Binding="{Binding InvestedCost}" Width="*" />
                                <DataGridTextColumn Header="PnL realise" Binding="{Binding RealizedPnl}" Width="*" />
                                <DataGridTextColumn Header="Frais" Binding="{Binding Fees}" Width="*" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </Border>

                <Border x:Name="AssetXrayPanel" Style="{StaticResource Panel}">
                    <StackPanel>
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock x:Name="AssetXrayTitleText" Text="Asset X-Ray" FontSize="20" FontWeight="SemiBold" />
                                <TextBlock x:Name="AssetXraySubtitleText" Text="Selectionne un actif pour voir les transactions qui expliquent la position." Foreground="#52606D" />
                            </StackPanel>
                            <TextBlock Grid.Column="1" x:Name="AssetXrayConfidenceText" Foreground="#B45309" FontWeight="SemiBold" />
                        </Grid>
                        <UniformGrid Columns="4" Margin="0,0,0,12">
                            <TextBlock x:Name="AssetXrayQuantityText" />
                            <TextBlock x:Name="AssetXrayAverageText" />
                            <TextBlock x:Name="AssetXrayCostText" />
                            <TextBlock x:Name="AssetXrayPnlText" />
                        </UniformGrid>
                        <DataGrid x:Name="AssetTransactionsGrid" AutoGenerateColumns="False" IsReadOnly="True" MinHeight="120">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Date" Binding="{Binding ExecutedAt}" Width="150" />
                                <DataGridTextColumn Header="Side" Binding="{Binding Side}" Width="70" />
                                <DataGridTextColumn Header="Quantite" Binding="{Binding Quantity}" Width="*" />
                                <DataGridTextColumn Header="Prix" Binding="{Binding UnitPrice}" Width="*" />
                                <DataGridTextColumn Header="Frais" Binding="{Binding Fee}" Width="*" />
                                <DataGridTextColumn Header="Source" Binding="{Binding Source}" Width="*" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </Border>

                <Border x:Name="ImportsAnchor" Background="#0B101B" BorderBrush="#263244" BorderThickness="1" CornerRadius="8" Padding="22" Margin="0,0,0,14">
                    <StackPanel>
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Import Binance" Foreground="White" FontSize="24" FontWeight="SemiBold" />
                                <TextBlock Text="Dashboard local: exports cumules, actifs resumes, ordres regroupes avant ecriture SQLite." Foreground="#94A3B8" Margin="0,4,0,0" />
                            </StackPanel>
                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <Button Content="Ajouter export" Click="LoadBinanceImport_Click" Background="#F0B90B" Foreground="#111827" FontWeight="SemiBold" />
                                <Button Content="Valider trades" Click="WriteImportableTrades_Click" Background="#22C55E" Foreground="#07111F" FontWeight="SemiBold" />
                                <Button Content="Reinitialiser" Click="ClearBinanceImports_Click" Background="#1F2937" Foreground="White" />
                            </StackPanel>
                        </Grid>

                        <UniformGrid Columns="5" Margin="0,0,0,16">
                            <Border Background="#111827" BorderBrush="#263244" BorderThickness="1" CornerRadius="8" Padding="14" Margin="0,0,10,0">
                                <StackPanel>
                                    <TextBlock Text="Volume trade" Foreground="#94A3B8" />
                                    <TextBlock x:Name="ImportVolumeText" Text="0" Foreground="White" FontSize="24" FontWeight="SemiBold" />
                                </StackPanel>
                            </Border>
                            <Border Background="#111827" BorderBrush="#263244" BorderThickness="1" CornerRadius="8" Padding="14" Margin="0,0,10,0">
                                <StackPanel>
                                    <TextBlock Text="Evenements" Foreground="#94A3B8" />
                                    <TextBlock x:Name="ImportEventCountText" Text="0" Foreground="White" FontSize="24" FontWeight="SemiBold" />
                                </StackPanel>
                            </Border>
                            <Border Background="#111827" BorderBrush="#263244" BorderThickness="1" CornerRadius="8" Padding="14" Margin="0,0,10,0">
                                <StackPanel>
                                    <TextBlock Text="Trades" Foreground="#94A3B8" />
                                    <TextBlock x:Name="ImportTradeCountText" Text="0" Foreground="#22C55E" FontSize="24" FontWeight="SemiBold" />
                                </StackPanel>
                            </Border>
                            <Border Background="#111827" BorderBrush="#263244" BorderThickness="1" CornerRadius="8" Padding="14" Margin="0,0,10,0">
                                <StackPanel>
                                    <TextBlock Text="A confirmer" Foreground="#94A3B8" />
                                    <TextBlock x:Name="ImportPendingCountText" Text="0" Foreground="#FBBF24" FontSize="24" FontWeight="SemiBold" />
                                </StackPanel>
                            </Border>
                            <Border Background="#111827" BorderBrush="#263244" BorderThickness="1" CornerRadius="8" Padding="14">
                                <StackPanel>
                                    <TextBlock Text="Actifs" Foreground="#94A3B8" />
                                    <TextBlock x:Name="ImportAssetCountText" Text="0" Foreground="#38BDF8" FontSize="24" FontWeight="SemiBold" />
                                </StackPanel>
                            </Border>
                        </UniformGrid>

                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="210" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Crypto" Foreground="#CBD5E1" />
                                <TextBox x:Name="ImportAssetFilterBox" CharacterCasing="Upper" TextChanged="ImportFilter_TextChanged" Background="#0F172A" Foreground="White" BorderBrush="#475569" />
                            </StackPanel>
                            <WrapPanel Grid.Column="1" Margin="12,18,0,0">
                                <Button Content="Tout" Tag="Tout" Click="ImportViewFilter_Click" Background="#F0B90B" Foreground="#111827" FontWeight="SemiBold" Padding="12,6" />
                                <Button Content="Trades" Tag="Trades" Click="ImportViewFilter_Click" Background="#1F2937" Foreground="White" Padding="12,6" />
                                <Button Content="Rewards" Tag="Earn / Rewards" Click="ImportViewFilter_Click" Background="#1F2937" Foreground="White" Padding="12,6" />
                                <Button Content="Internes" Tag="Internes" Click="ImportViewFilter_Click" Background="#1F2937" Foreground="White" Padding="12,6" />
                                <Button Content="A confirmer" Tag="A confirmer" Click="ImportViewFilter_Click" Background="#1F2937" Foreground="White" Padding="12,6" />
                            </WrapPanel>
                        </Grid>
                        <TextBlock x:Name="ImportFileText" Foreground="#94A3B8" TextWrapping="Wrap" Margin="0,0,0,12" />

                        <TabControl x:Name="ImportTabs" Background="#0B101B" BorderBrush="#263244" Foreground="White">
                            <TabItem x:Name="ImportSummaryTab" Header="Resume">
                                <Grid Background="#0B101B" Margin="0,12,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="1.2*" />
                                        <ColumnDefinition Width="1*" />
                                    </Grid.ColumnDefinitions>
                                    <Border Background="#111827" BorderBrush="#263244" BorderThickness="1" CornerRadius="8" Padding="16" Margin="0,0,12,0">
                                        <StackPanel>
                                            <TextBlock Text="Repartition" Foreground="White" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,10" />
                                            <ItemsControl x:Name="ImportChartItems">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Grid Margin="0,5">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="120" />
                                                                <ColumnDefinition Width="*" />
                                                                <ColumnDefinition Width="60" />
                                                            </Grid.ColumnDefinitions>
                                                            <TextBlock Text="{Binding Label}" Foreground="#CBD5E1" />
                                                            <Grid Grid.Column="1" Height="14" Background="#1E293B">
                                                                <Border Background="{Binding Color}" Width="{Binding Width}" HorizontalAlignment="Left" CornerRadius="7" />
                                                            </Grid>
                                                            <TextBlock Grid.Column="2" Text="{Binding Count}" Foreground="White" HorizontalAlignment="Right" />
                                                        </Grid>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </Border>
                                    <Border Grid.Column="1" Background="#111827" BorderBrush="#263244" BorderThickness="1" CornerRadius="8" Padding="16">
                                        <StackPanel>
                                            <TextBlock Text="Derniers ordres regroupes" Foreground="White" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,10" />
                                            <ItemsControl x:Name="ImportRecentOrdersItems">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Grid Margin="0,6">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="42" />
                                                                <ColumnDefinition Width="*" />
                                                                <ColumnDefinition Width="Auto" />
                                                            </Grid.ColumnDefinitions>
                                                            <Border Width="30" Height="30" CornerRadius="15" Background="{Binding Accent}">
                                                                <TextBlock Text="{Binding Logo}" Foreground="#0B101B" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                            </Border>
                                                            <StackPanel Grid.Column="1">
                                                                <TextBlock Text="{Binding Title}" Foreground="White" FontWeight="SemiBold" />
                                                                <TextBlock Text="{Binding Subtitle}" Foreground="#94A3B8" />
                                                            </StackPanel>
                                                            <TextBlock Grid.Column="2" Text="{Binding Status}" Foreground="{Binding StatusColor}" FontWeight="SemiBold" />
                                                        </Grid>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </TabItem>
                            <TabItem x:Name="ImportAssetsTab" Header="Actifs">
                                <ItemsControl x:Name="ImportAssetItems" Background="#0B101B" Margin="0,12,0,0">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="#111827" BorderBrush="#263244" BorderThickness="1" CornerRadius="8" Padding="14" Margin="0,0,0,8">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="52" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="130" />
                                                        <ColumnDefinition Width="130" />
                                                        <ColumnDefinition Width="130" />
                                                        <ColumnDefinition Width="110" />
                                                    </Grid.ColumnDefinitions>
                                                    <Border Width="36" Height="36" CornerRadius="18" Background="{Binding Accent}">
                                                        <TextBlock Text="{Binding Logo}" Foreground="#0B101B" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                    </Border>
                                                    <StackPanel Grid.Column="1">
                                                        <TextBlock Text="{Binding Asset}" Foreground="White" FontSize="16" FontWeight="SemiBold" />
                                                        <TextBlock Text="{Binding Description}" Foreground="#94A3B8" />
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="2">
                                                        <TextBlock Text="Net" Foreground="#64748B" />
                                                        <TextBlock Text="{Binding NetQuantity}" Foreground="White" FontWeight="SemiBold" />
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="3">
                                                        <TextBlock Text="Trades" Foreground="#64748B" />
                                                        <TextBlock Text="{Binding TradeCount}" Foreground="#22C55E" FontWeight="SemiBold" />
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="4">
                                                        <TextBlock Text="A confirmer" Foreground="#64748B" />
                                                        <TextBlock Text="{Binding PendingCount}" Foreground="#FBBF24" FontWeight="SemiBold" />
                                                    </StackPanel>
                                                    <Button Grid.Column="5" Content="Voir ordres" Tag="{Binding Asset}" Click="ImportAsset_Click" Background="#F0B90B" Foreground="#111827" FontWeight="SemiBold" Padding="10,6" Margin="0" />
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </TabItem>
                            <TabItem x:Name="ImportOrdersTab" Header="Ordres">
                                <DataGrid x:Name="ImportPreviewGrid" AutoGenerateColumns="False" IsReadOnly="True" MinHeight="260"
                                          Background="#0F172A" Foreground="#E2E8F0" RowBackground="#111827" AlternatingRowBackground="#172033"
                                          BorderBrush="#334155" GridLinesVisibility="None" HeadersVisibility="Column" Margin="0,12,0,0"
                                          ColumnHeaderStyle="{StaticResource DarkGridHeader}" CellStyle="{StaticResource DarkGridCell}">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="#" Binding="{Binding EventNumber}" Width="55" />
                                        <DataGridTextColumn Header="Date" Binding="{Binding ExecutedAt}" Width="145" />
                                        <DataGridTextColumn Header="Type" Binding="{Binding Kind}" Width="90" />
                                        <DataGridTextColumn Header="Crypto" Binding="{Binding Asset}" Width="80" />
                                        <DataGridTextColumn Header="Quantite" Binding="{Binding Quantity}" Width="110" />
                                        <DataGridTextColumn Header="Contrepartie" Binding="{Binding Quote}" Width="130" />
                                        <DataGridTextColumn Header="Prix execution" Binding="{Binding UnitPrice}" Width="125" />
                                        <DataGridTextColumn Header="Frais" Binding="{Binding Fee}" Width="110" />
                                        <DataGridTextColumn Header="Source" Binding="{Binding SourceKind}" Width="105" />
                                        <DataGridTextColumn Header="ID ordre" Binding="{Binding ExternalId}" Width="110" />
                                        <DataGridTextColumn Header="Statut" Binding="{Binding Status}" Width="105" />
                                        <DataGridTextColumn Header="Decision" Binding="{Binding Reason}" Width="2*" />
                                    </DataGrid.Columns>
                                </DataGrid>
                            </TabItem>
                        </TabControl>

                        <TextBlock x:Name="ImportFeedbackText" Foreground="#FBBF24" Margin="0,10,0,0" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <Border x:Name="DataAnchor" Style="{StaticResource Panel}">
                    <StackPanel>
                        <TextBlock Text="Donnees" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,12" />
                        <TextBlock Text="Source de verite SQLite active" Foreground="#52606D" />
                        <TextBlock x:Name="DataFileText" TextWrapping="Wrap" FontWeight="SemiBold" Margin="0,4,0,12" />
                        <TextBlock Text="Ancien cache Electron: hors flux principal WPF. Ne pas l'utiliser comme source portefeuille." Foreground="#52606D" TextWrapping="Wrap" Margin="0,0,0,12" />
                        <StackPanel Orientation="Horizontal">
                            <Button Content="Sauvegarder SQLite" Click="BackupDatabase_Click" Background="#047857" Foreground="White" />
                            <Button Content="Restaurer SQLite" Click="RestoreDatabase_Click" Background="#B45309" Foreground="White" />
                        </StackPanel>
                        <TextBlock x:Name="DataFeedbackText" Foreground="#52606D" Margin="0,8,0,0" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource Panel}">
                    <StackPanel>
                        <TextBlock Text="Journal" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,12" />
                        <DataGrid x:Name="TransactionsGrid" AutoGenerateColumns="False" IsReadOnly="True" MinHeight="220">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Date" Binding="{Binding ExecutedAt}" Width="150" />
                                <DataGridTextColumn Header="Side" Binding="{Binding Side}" Width="80" />
                                <DataGridTextColumn Header="Actif" Binding="{Binding Symbol}" Width="90" />
                                <DataGridTextColumn Header="Quantite" Binding="{Binding Quantity}" Width="*" />
                                <DataGridTextColumn Header="Prix" Binding="{Binding UnitPrice}" Width="*" />
                                <DataGridTextColumn Header="Frais" Binding="{Binding Fee}" Width="*" />
                                <DataGridTextColumn Header="Source" Binding="{Binding Source}" Width="*" />
                                <DataGridTextColumn Header="Note" Binding="{Binding Note}" Width="2*" />
                                <DataGridTemplateColumn Header="" Width="110">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button Content="Supprimer" Tag="{Binding Id}" Click="DeleteTransaction_Click" Padding="8,4" Margin="0" />
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>
