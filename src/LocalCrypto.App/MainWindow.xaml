<Window x:Class="LocalCrypto.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:LocalCrypto.App.Views"
        Title="localCrypto" Height="840" Width="1260" MinHeight="720" MinWidth="1080"
        Background="#090E18" WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI" />
            <Setter Property="Foreground" Value="#E5E7EB" />
        </Style>
        <Style TargetType="Button">
            <Setter Property="FontFamily" Value="Segoe UI" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
        <Style x:Key="NavButton" TargetType="Button">
            <Setter Property="FontFamily" Value="Segoe UI" />
            <Setter Property="Padding" Value="12,10" />
            <Setter Property="Margin" Value="0,0,0,8" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="#A8B3C7" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="244" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#111A29" Padding="20">
            <DockPanel LastChildFill="True">
                <StackPanel DockPanel.Dock="Top">
                    <TextBlock Text="localCrypto" Foreground="White" FontSize="26" FontWeight="SemiBold" />
                    <TextBlock Text="Cockpit ledger local" Foreground="#8FA1BD" Margin="0,4,0,26" />

                    <TextBlock Text="V0.1.2 WPF" Foreground="#F0B90B" FontWeight="SemiBold" />
                    <TextBlock Text="SQLite local-first" Foreground="#8FA1BD" Margin="0,4,0,28" />

                    <Button Content="Tableau de bord" Tag="Dashboard" Click="NavigateSection_Click" Style="{StaticResource NavButton}" Background="#1C273A" Foreground="White" />
                    <Button Content="Positions" Tag="Positions" Click="NavigateSection_Click" Style="{StaticResource NavButton}" />
                    <Button Content="Import Studio" Tag="Imports" Click="NavigateSection_Click" Style="{StaticResource NavButton}" />
                    <Button Content="Donnees" Tag="Data" Click="NavigateSection_Click" Style="{StaticResource NavButton}" />
                </StackPanel>

                <StackPanel DockPanel.Dock="Bottom">
                    <Border Background="#0B101B" BorderBrush="#263244" BorderThickness="1" CornerRadius="8" Padding="12">
                        <StackPanel>
                            <TextBlock Text="Source de verite" Foreground="#8FA1BD" FontSize="12" />
                            <TextBlock x:Name="DatabasePathText" TextWrapping="Wrap" Foreground="#E5E7EB" Margin="0,6,0,0" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </DockPanel>
        </Border>

        <ScrollViewer x:Name="MainScrollViewer" Grid.Column="1" VerticalScrollBarVisibility="Auto" Background="#090E18">
            <StackPanel Margin="24">
                <views:DashboardView x:Name="DashboardView" />
                <views:PositionsView x:Name="PositionsView" AssetProofRequested="PositionsView_AssetProofRequested" />
                <views:ImportStudioView x:Name="ImportStudioView"
                                        AddExportRequested="ImportStudioView_AddExportRequested"
                                        ValidateTradesRequested="ImportStudioView_ValidateTradesRequested"
                                        ResetRequested="ImportStudioView_ResetRequested"
                                        FiltersChanged="ImportStudioView_FiltersChanged" />
                <views:DataView x:Name="DataView"
                                BackupRequested="DataView_BackupRequested"
                                RestoreRequested="DataView_RestoreRequested"
                                ClearLedgerRequested="DataView_ClearLedgerRequested"
                                DeleteTransactionRequested="DataView_DeleteTransactionRequested" />
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>
