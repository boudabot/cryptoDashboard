<Window x:Class="LocalCrypto.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:LocalCrypto.App.Views"
        Title="localCrypto" Height="840" Width="1260" MinHeight="720" MinWidth="1080"
        Background="{StaticResource Brush.AppBackground}" WindowStartupLocation="CenterScreen"
        SizeChanged="Window_SizeChanged">
    <Window.Resources>
        <Style x:Key="NavButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="FontFamily" Value="Segoe UI" />
            <Setter Property="Padding" Value="12,10" />
            <Setter Property="Margin" Value="0,0,0,7" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="#A8B3C7" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
        <Style x:Key="NavGroupButton" BasedOn="{StaticResource NavButton}" TargetType="Button">
            <Setter Property="Foreground" Value="#E5E7EB" />
            <Setter Property="FontSize" Value="15" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,14,0,8" />
        </Style>
        <Style x:Key="NavSubButton" BasedOn="{StaticResource NavButton}" TargetType="Button">
            <Setter Property="Padding" Value="26,9,12,9" />
            <Setter Property="Foreground" Value="#98A4B8" />
            <Setter Property="FontSize" Value="14" />
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="244" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="{StaticResource Brush.Sidebar}" Padding="18" BorderBrush="#1E2B41" BorderThickness="0,0,1,0">
            <DockPanel LastChildFill="True">
                <StackPanel DockPanel.Dock="Top">
                    <TextBlock Text="localCrypto" Foreground="White" FontSize="28" FontWeight="SemiBold" />
                    <Border Height="2" Width="76" HorizontalAlignment="Left" Margin="0,8,0,8" Background="#F0B90B" CornerRadius="1" />
                    <TextBlock Text="Cockpit ledger local" Foreground="#8FA1BD" Margin="0,0,0,24" />

                    <TextBlock Text="V0.1.2 WPF" Foreground="#F0B90B" FontWeight="SemiBold" />
                    <TextBlock Text="SQLite local-first" Foreground="#8FA1BD" Margin="0,4,0,28" />

                    <Button x:Name="DashboardNavButton" Content="Tableau de bord" Tag="Dashboard" Click="NavigateSection_Click" Style="{StaticResource NavButton}" />

                    <Button x:Name="AssetsGroupButton" Click="ToggleNavGroup_Click" Tag="Assets" Style="{StaticResource NavGroupButton}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Actifs" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" FontWeight="SemiBold" />
                            <TextBlock x:Name="AssetsChevronText" Grid.Column="1" Text="-" Foreground="#A8B3C7" />
                        </Grid>
                    </Button>
                    <StackPanel x:Name="AssetsMenu">
                        <Button x:Name="AssetsOverviewNavButton" Content="Vue globale" Tag="AssetsOverview" Click="NavigateSection_Click" Style="{StaticResource NavSubButton}" />
                        <Button x:Name="SpotNavButton" Content="Spot / Positions" Tag="Positions" Click="NavigateSection_Click" Style="{StaticResource NavSubButton}" />
                        <Button x:Name="EarnNavButton" Content="Earn / Rewards" Tag="Earn" Click="NavigateSection_Click" Style="{StaticResource NavSubButton}" />
                        <Button x:Name="AlphaNavButton" Content="Alpha" Tag="Alpha" Click="NavigateSection_Click" Style="{StaticResource NavSubButton}" />
                        <Button x:Name="ReconciliationNavButton" Content="Ecarts / Reconciliation" Tag="Reconciliation" Click="NavigateSection_Click" Style="{StaticResource NavSubButton}" />
                    </StackPanel>

                    <Button x:Name="BinanceApiNavButton" Content="Binance API / Compte" Tag="BinanceApi" Click="NavigateSection_Click" Style="{StaticResource NavButton}" Margin="0,16,0,6" />

                    <Button x:Name="OrdersGroupButton" Click="ToggleNavGroup_Click" Tag="Orders" Style="{StaticResource NavGroupButton}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Ordres" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" FontWeight="SemiBold" />
                            <TextBlock x:Name="OrdersChevronText" Grid.Column="1" Text="+" Foreground="#A8B3C7" />
                        </Grid>
                    </Button>
                    <StackPanel x:Name="OrdersMenu" Visibility="Collapsed">
                        <Button x:Name="OpenOrdersNavButton" Content="Ordres ouverts" Tag="OpenOrders" Click="NavigateSection_Click" Style="{StaticResource NavSubButton}" />
                        <Button x:Name="ImportNavButton" Content="Import Studio" Tag="Imports" Click="NavigateSection_Click" Style="{StaticResource NavSubButton}" />
                        <Button x:Name="LedgerNavButton" Content="Journal ledger" Tag="Data" Click="NavigateSection_Click" Style="{StaticResource NavSubButton}" />
                    </StackPanel>

                    <Button x:Name="DataNavButton" Content="Donnees" Tag="Data" Click="NavigateSection_Click" Style="{StaticResource NavButton}" Margin="0,16,0,6" />
                </StackPanel>

                <StackPanel DockPanel.Dock="Bottom">
                    <Border Background="#090F1B" BorderBrush="#263244" BorderThickness="1" CornerRadius="8" Padding="12" Effect="{StaticResource Effect.PanelGlow}">
                        <StackPanel>
                            <TextBlock Text="Source de verite" Foreground="#8FA1BD" FontSize="12" />
                            <TextBlock x:Name="DatabasePathText" TextWrapping="Wrap" Foreground="#E5E7EB" Margin="0,6,0,0" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </DockPanel>
        </Border>

        <ScrollViewer x:Name="MainScrollViewer" Grid.Column="1" VerticalScrollBarVisibility="Auto" Background="{StaticResource Brush.AppBackground}">
            <Grid Margin="24">
                <views:DashboardView x:Name="DashboardView" RefreshBinanceRequested="DashboardView_RefreshBinanceRequested" />
                <views:AssetsOverviewView x:Name="AssetsOverviewView" Visibility="Collapsed" />
                <views:PositionsView x:Name="PositionsView" Visibility="Collapsed" AssetProofRequested="PositionsView_AssetProofRequested" />
                <views:EarnView x:Name="EarnView" Visibility="Collapsed" />
                <views:AlphaView x:Name="AlphaView" Visibility="Collapsed" />
                <views:OpenOrdersView x:Name="OpenOrdersView" Visibility="Collapsed" />
                <views:ReconciliationView x:Name="ReconciliationView" Visibility="Collapsed" />
                <views:BinanceApiView x:Name="BinanceApiView"
                                      Visibility="Collapsed"
                                      SaveCredentialsRequested="BinanceApiView_SaveCredentialsRequested"
                                      TestConnectionRequested="BinanceApiView_TestConnectionRequested"
                                      ClearCredentialsRequested="BinanceApiView_ClearCredentialsRequested"
                                      RefreshSpotRequested="BinanceApiView_RefreshSpotRequested" />
                <views:ImportStudioView x:Name="ImportStudioView"
                                        Visibility="Collapsed"
                                        AddExportRequested="ImportStudioView_AddExportRequested"
                                        ValidateTradesRequested="ImportStudioView_ValidateTradesRequested"
                                        ResetRequested="ImportStudioView_ResetRequested"
                                        FiltersChanged="ImportStudioView_FiltersChanged" />
                <views:DataView x:Name="DataView"
                                Visibility="Collapsed"
                                BackupRequested="DataView_BackupRequested"
                                RestoreRequested="DataView_RestoreRequested"
                                ClearLedgerRequested="DataView_ClearLedgerRequested"
                                ClearBinanceCacheRequested="DataView_ClearBinanceCacheRequested"
                                DeleteTransactionRequested="DataView_DeleteTransactionRequested" />
            </Grid>
        </ScrollViewer>
    </Grid>
</Window>
