<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <SolidColorBrush x:Key="Color.AppBg" Color="#060A12" />
    <SolidColorBrush x:Key="Color.Surface" Color="#0B1220" />
    <SolidColorBrush x:Key="Color.SurfaceRaised" Color="#101A2B" />
    <SolidColorBrush x:Key="Color.SurfaceSoft" Color="#16243A" />
    <SolidColorBrush x:Key="Color.Border" Color="#2A3A55" />
    <SolidColorBrush x:Key="Color.BorderBright" Color="#48668D" />
    <SolidColorBrush x:Key="Color.Text" Color="#F4F7FB" />
    <SolidColorBrush x:Key="Color.Muted" Color="#92A1B9" />
    <SolidColorBrush x:Key="Color.Subtle" Color="#5F708B" />
    <SolidColorBrush x:Key="Color.Binance" Color="#F0B90B" />
    <SolidColorBrush x:Key="Color.Cyan" Color="#38BDF8" />
    <SolidColorBrush x:Key="Color.Green" Color="#22C55E" />
    <SolidColorBrush x:Key="Color.Red" Color="#F87171" />

    <LinearGradientBrush x:Key="Brush.AppBackground" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#060A12" Offset="0" />
        <GradientStop Color="#09111F" Offset="0.48" />
        <GradientStop Color="#070B14" Offset="1" />
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="Brush.Sidebar" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#121D30" Offset="0" />
        <GradientStop Color="#0B1320" Offset="1" />
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="Brush.Card" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#121D31" Offset="0" />
        <GradientStop Color="#0B1220" Offset="0.68" />
        <GradientStop Color="#090F1B" Offset="1" />
    </LinearGradientBrush>

    <DropShadowEffect x:Key="Effect.PanelGlow" Color="#1E90FF" BlurRadius="22" ShadowDepth="0" Opacity="0.16" />
    <DropShadowEffect x:Key="Effect.AccentGlow" Color="#F0B90B" BlurRadius="18" ShadowDepth="0" Opacity="0.20" />

    <Style TargetType="{x:Type TextBlock}">
        <Setter Property="FontFamily" Value="Segoe UI" />
        <Setter Property="Foreground" Value="{StaticResource Color.Text}" />
        <Setter Property="TextOptions.TextFormattingMode" Value="Display" />
    </Style>

    <Style TargetType="{x:Type Button}">
        <Setter Property="FontFamily" Value="Segoe UI" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="MinHeight" Value="34" />
        <Setter Property="Padding" Value="12,8" />
        <Setter Property="Background" Value="{StaticResource Color.SurfaceSoft}" />
        <Setter Property="Foreground" Value="{StaticResource Color.Text}" />
        <Setter Property="BorderBrush" Value="{StaticResource Color.BorderBright}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Button}">
                    <Border x:Name="ButtonChrome"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="6"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="ButtonChrome" Property="BorderBrush" Value="{StaticResource Color.Binance}" />
                            <Setter TargetName="ButtonChrome" Property="Effect" Value="{StaticResource Effect.AccentGlow}" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="ButtonChrome" Property="Opacity" Value="0.82" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="ButtonChrome" Property="Opacity" Value="0.45" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="{x:Type TextBox}">
        <Setter Property="Background" Value="#0B1220" />
        <Setter Property="Foreground" Value="{StaticResource Color.Text}" />
        <Setter Property="CaretBrush" Value="{StaticResource Color.Binance}" />
        <Setter Property="BorderBrush" Value="{StaticResource Color.BorderBright}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="10,7" />
        <Setter Property="SelectionBrush" Value="#725A12" />
    </Style>

    <Style TargetType="{x:Type PasswordBox}">
        <Setter Property="Background" Value="#0B1220" />
        <Setter Property="Foreground" Value="{StaticResource Color.Text}" />
        <Setter Property="CaretBrush" Value="{StaticResource Color.Binance}" />
        <Setter Property="BorderBrush" Value="{StaticResource Color.BorderBright}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="10,7" />
        <Setter Property="SelectionBrush" Value="#725A12" />
    </Style>

    <Style TargetType="{x:Type DataGrid}">
        <Setter Property="Background" Value="#0A101C" />
        <Setter Property="Foreground" Value="{StaticResource Color.Text}" />
        <Setter Property="BorderBrush" Value="{StaticResource Color.Border}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="GridLinesVisibility" Value="None" />
        <Setter Property="HeadersVisibility" Value="Column" />
        <Setter Property="RowBackground" Value="#0E1728" />
        <Setter Property="AlternatingRowBackground" Value="#121E32" />
        <Setter Property="HorizontalGridLinesBrush" Value="#1E2B41" />
        <Setter Property="VerticalGridLinesBrush" Value="#1E2B41" />
        <Setter Property="FontSize" Value="12" />
    </Style>

    <Style TargetType="{x:Type DataGridColumnHeader}">
        <Setter Property="Background" Value="#101827" />
        <Setter Property="Foreground" Value="#AFC0D8" />
        <Setter Property="BorderBrush" Value="#25344C" />
        <Setter Property="BorderThickness" Value="0,0,1,1" />
        <Setter Property="Padding" Value="10,8" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style TargetType="{x:Type DataGridCell}">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{StaticResource Color.Text}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="8,5" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type DataGridCell}">
                    <Border Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                        <ContentPresenter VerticalAlignment="Center" />
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="{x:Type DataGridRow}">
        <Setter Property="MinHeight" Value="26" />
        <Setter Property="BorderThickness" Value="0" />
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="#1A2943" />
            </Trigger>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background" Value="#243758" />
            </Trigger>
        </Style.Triggers>
    </Style>
</ResourceDictionary>
