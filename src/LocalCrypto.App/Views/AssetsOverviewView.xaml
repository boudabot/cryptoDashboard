<UserControl x:Class="LocalCrypto.App.Views.AssetsOverviewView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:LocalCrypto.App.Controls">
    <StackPanel x:Name="RootAnchor">
        <Grid Margin="0,0,0,18">
            <StackPanel>
                <TextBlock Text="Actifs - vue globale" FontSize="30" FontWeight="SemiBold" Foreground="White" />
                <TextBlock Text="Carte des sources: ledger valide, Binance live, cache marche et imports restent separes." Foreground="#8FA1BD" Margin="0,4,0,0" />
            </StackPanel>
        </Grid>

        <UniformGrid x:Name="SourceGrid" Columns="4" Margin="0,0,0,16">
            <controls:MetricCard x:Name="LedgerCard" Label="Ledger SQLite" ValueBrush="#22C55E" />
            <controls:MetricCard x:Name="BinanceCard" Label="Source Binance" ValueBrush="#38BDF8" />
            <controls:MetricCard x:Name="MarketCacheCard" Label="Market cache" ValueBrush="#FBBF24" />
            <controls:MetricCard x:Name="ImportPreviewCard" Label="Import preview" ValueBrush="#F97316" />
        </UniformGrid>

        <Grid x:Name="OverviewPanelsGrid">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Border Background="{StaticResource Brush.Card}" BorderBrush="#263A55" BorderThickness="1" CornerRadius="8" Padding="18" Effect="{StaticResource Effect.PanelGlow}">
                <StackPanel>
                    <TextBlock Text="Ce que la vue Actifs doit montrer" Foreground="White" FontSize="20" FontWeight="SemiBold" />
                    <TextBlock Text="Spot, Earn et Alpha sont des espaces differents. Un actif Alpha ne doit pas etre presente comme une position Spot classique sans label de source." Foreground="#8FA1BD" TextWrapping="Wrap" Margin="0,8,0,14" />

                    <Border Background="#0B1220" BorderBrush="#263244" BorderThickness="1" CornerRadius="8" Padding="14" Margin="0,0,0,10">
                        <StackPanel>
                            <TextBlock Text="Ledger valide" Foreground="#22C55E" FontWeight="SemiBold" />
                            <TextBlock Text="Transactions SQLite, PnL realise, prix moyen et preuves. C'est la verite portefeuille locale." Foreground="#CBD5E1" TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>

                    <Border Background="#0B1220" BorderBrush="#263244" BorderThickness="1" CornerRadius="8" Padding="14" Margin="0,0,0,10">
                        <StackPanel>
                            <TextBlock Text="Source Binance" Foreground="#38BDF8" FontWeight="SemiBold" />
                            <TextBlock Text="Observation live read-only: Spot, Earn, ordres ouverts. Indicatif, jamais ecriture ledger automatique." Foreground="#CBD5E1" TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>

                    <Border Background="#0B1220" BorderBrush="#263244" BorderThickness="1" CornerRadius="8" Padding="14">
                        <StackPanel>
                            <TextBlock Text="Import preview" Foreground="#F97316" FontWeight="SemiBold" />
                            <TextBlock Text="Fichiers CSV/XLSX pour audit, reconstruction, comparaison et validation explicite." Foreground="#CBD5E1" TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>

            <Border x:Name="WorkflowPanel" Grid.Column="2" Background="{StaticResource Brush.Card}" BorderBrush="#263A55" BorderThickness="1" CornerRadius="8" Padding="18">
                <StackPanel>
                    <TextBlock Text="Workflow recommande" Foreground="White" FontSize="20" FontWeight="SemiBold" />
                    <TextBlock Text="1. Lire les actifs valides depuis le ledger." Foreground="#CBD5E1" Margin="0,12,0,0" />
                    <TextBlock Text="2. Observer Binance live sans modifier SQLite." Foreground="#CBD5E1" Margin="0,8,0,0" />
                    <TextBlock Text="3. Afficher les ecarts au lieu de les masquer." Foreground="#CBD5E1" Margin="0,8,0,0" />
                    <TextBlock Text="4. Utiliser Import Studio seulement pour fichiers et reconciliation historique." Foreground="#CBD5E1" Margin="0,8,0,0" />

                    <Border Background="#0B1220" BorderBrush="#F0B90B" BorderThickness="1" CornerRadius="8" Padding="14" Margin="0,18,0,0">
                        <StackPanel>
                            <TextBlock Text="Boussole UI" Foreground="#F0B90B" FontWeight="SemiBold" />
                            <TextBlock Text="Le design doit rendre les sources comprehensibles. Il ne doit jamais faire croire que Spot, Earn, Alpha, ledger et import racontent la meme chose." Foreground="#E5E7EB" TextWrapping="Wrap" Margin="0,6,0,0" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>
        </Grid>
    </StackPanel>
</UserControl>
