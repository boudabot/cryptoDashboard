<UserControl x:Class="LocalCrypto.App.Views.ImportStudioView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:LocalCrypto.App.Controls">
    <UserControl.Resources>
        <Style TargetType="{x:Type TabItem}">
            <Setter Property="Foreground" Value="#A8B3C7" />
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="Margin" Value="0,0,6,0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type TabItem}">
                        <Border x:Name="TabBorder" Background="#111827" BorderBrush="#263244" BorderThickness="1" CornerRadius="6,6,0,0" Padding="{TemplateBinding Padding}">
                            <ContentPresenter ContentSource="Header" HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="TabBorder" Property="Background" Value="#F0B90B" />
                                <Setter TargetName="TabBorder" Property="BorderBrush" Value="#F0B90B" />
                                <Setter Property="Foreground" Value="#111827" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="TabBorder" Property="Opacity" Value="0.5" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Border x:Name="RootAnchor" Background="#0B101B" BorderBrush="#263244" BorderThickness="1" CornerRadius="8" Padding="22" Margin="0,0,0,14">
        <StackPanel>
            <Grid Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="Import Studio" Foreground="White" FontSize="24" FontWeight="SemiBold" />
                    <TextBlock Text="Preview Binance non validee: rien ici n'est verite portefeuille tant que tu ne valides pas dans SQLite." Foreground="#94A3B8" Margin="0,4,0,0" />
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Content="Ajouter export" Click="AddExport_Click" Background="#F0B90B" Foreground="#111827" BorderBrush="#F0B90B" FontWeight="SemiBold" Padding="14,10" Margin="0,0,10,0" />
                    <Button Content="Valider trades" Click="ValidateTrades_Click" Background="#22C55E" Foreground="#07111F" BorderBrush="#22C55E" FontWeight="SemiBold" Padding="14,10" Margin="0,0,10,0" />
                    <Button Content="Reinitialiser" Click="Reset_Click" Background="#1F2937" Foreground="White" BorderBrush="#334155" Padding="14,10" />
                </StackPanel>
            </Grid>

            <UniformGrid x:Name="ImportMetricsGrid" Columns="6" Margin="0,0,0,16">
                <controls:MetricCard x:Name="ImportVolumeCard" Label="Volume preview" />
                <controls:MetricCard x:Name="ImportEventCountCard" Label="Evenements" />
                <controls:MetricCard x:Name="ImportTradeCountCard" Label="Trades" ValueBrush="#22C55E" />
                <controls:MetricCard x:Name="ImportPendingCountCard" Label="A confirmer" ValueBrush="#FBBF24" />
                <controls:MetricCard x:Name="ImportAssetCountCard" Label="Actifs" ValueBrush="#38BDF8" />
                <controls:MetricCard x:Name="ImportQuarantineCountCard" Label="Quarantaine" ValueBrush="#F97316" />
            </UniformGrid>

            <Border Background="#111827" BorderBrush="#263244" BorderThickness="1" CornerRadius="8" Padding="14" Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock Text="Actifs detectes" Foreground="#CBD5E1" FontWeight="SemiBold" Margin="0,0,0,8" />
                    <ItemsControl x:Name="AssetChipItems">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <controls:AssetChip ChipClicked="AssetChip_ChipClicked" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <Grid Margin="0,8,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="220" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="Recherche crypto" Foreground="#94A3B8" />
                            <TextBox x:Name="AssetFilterBox" CharacterCasing="Upper" TextChanged="AssetFilter_TextChanged" Background="#0F172A" Foreground="#E5E7EB" BorderBrush="#334155" Padding="8,6" />
                        </StackPanel>
                        <TextBlock Grid.Column="1" x:Name="ImportFileText" Foreground="#94A3B8" TextWrapping="Wrap" VerticalAlignment="Bottom" Margin="12,0,0,12" />
                    </Grid>
                </StackPanel>
            </Border>

            <Grid Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="Types" Foreground="#CBD5E1" FontWeight="SemiBold" />
                    <WrapPanel Margin="0,6,0,0">
                        <Button Content="Tous" Tag="All" Click="TypeFilter_Click" Background="#F0B90B" Foreground="#111827" BorderBrush="#F0B90B" Padding="12,6" Margin="0,0,8,0" />
                        <Button Content="Trades" Tag="Trades" Click="TypeFilter_Click" Background="#182235" Foreground="#E5E7EB" BorderBrush="#334155" Padding="12,6" Margin="0,0,8,0" />
                        <Button Content="Earn/Rewards" Tag="Rewards" Click="TypeFilter_Click" Background="#182235" Foreground="#E5E7EB" BorderBrush="#334155" Padding="12,6" Margin="0,0,8,0" />
                        <Button Content="Transferts" Tag="Transfers" Click="TypeFilter_Click" Background="#182235" Foreground="#E5E7EB" BorderBrush="#334155" Padding="12,6" Margin="0,0,8,0" />
                        <Button Content="Autres" Tag="Other" Click="TypeFilter_Click" Background="#182235" Foreground="#E5E7EB" BorderBrush="#334155" Padding="12,6" />
                    </WrapPanel>
                </StackPanel>
                <StackPanel Grid.Column="1">
                    <TextBlock Text="Statuts" Foreground="#CBD5E1" FontWeight="SemiBold" />
                    <WrapPanel Margin="0,6,0,0">
                        <Button Content="Tous" Tag="All" Click="StatusFilter_Click" Background="#F0B90B" Foreground="#111827" BorderBrush="#F0B90B" Padding="12,6" Margin="0,0,8,0" />
                        <Button Content="Nouveaux" Tag="New" Click="StatusFilter_Click" Background="#182235" Foreground="#E5E7EB" BorderBrush="#334155" Padding="12,6" Margin="0,0,8,0" />
                        <Button Content="Doublons" Tag="Duplicates" Click="StatusFilter_Click" Background="#182235" Foreground="#E5E7EB" BorderBrush="#334155" Padding="12,6" Margin="0,0,8,0" />
                        <Button Content="A confirmer" Tag="Pending" Click="StatusFilter_Click" Background="#182235" Foreground="#E5E7EB" BorderBrush="#334155" Padding="12,6" Margin="0,0,8,0" />
                        <Button Content="Ignores" Tag="Ignored" Click="StatusFilter_Click" Background="#182235" Foreground="#E5E7EB" BorderBrush="#334155" Padding="12,6" />
                    </WrapPanel>
                </StackPanel>
            </Grid>

            <TabControl x:Name="ImportTabs" Background="#0B101B" BorderBrush="#263244" Foreground="#E5E7EB">
                <TabItem x:Name="ImportSummaryTab" Header="Resume">
                    <Grid Background="#0B101B" Margin="0,12,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.1*" />
                            <ColumnDefinition Width="1*" />
                        </Grid.ColumnDefinitions>
                        <Border Background="#111827" BorderBrush="#263244" BorderThickness="1" CornerRadius="8" Padding="16" Margin="0,0,12,0">
                            <StackPanel>
                                <TextBlock Text="Repartition preview" Foreground="White" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,10" />
                                <ItemsControl x:Name="ImportChartItems" />
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="1" Background="#111827" BorderBrush="#263244" BorderThickness="1" CornerRadius="8" Padding="16">
                            <StackPanel>
                                <TextBlock Text="Derniers ordres regroupes" Foreground="White" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,10" />
                                <ItemsControl x:Name="ImportRecentOrdersItems" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </TabItem>
                <TabItem x:Name="ImportAssetsTab" Header="Actifs">
                    <ItemsControl x:Name="ImportAssetItems" Background="#0B101B" Margin="0,12,0,0" />
                </TabItem>
                <TabItem x:Name="ImportOrdersTab" Header="Ordres">
                    <DataGrid x:Name="ImportPreviewGrid" AutoGenerateColumns="False" IsReadOnly="True" MinHeight="260"
                              Background="#0F172A" Foreground="#E2E8F0" RowBackground="#111827" AlternatingRowBackground="#172033"
                              BorderBrush="#334155" GridLinesVisibility="None" HeadersVisibility="Column" Margin="0,12,0,0">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="#" Binding="{Binding EventNumber}" Width="55" />
                            <DataGridTextColumn Header="Date" Binding="{Binding ExecutedAt}" Width="145" />
                            <DataGridTextColumn Header="Type" Binding="{Binding Kind}" Width="90" />
                            <DataGridTextColumn Header="Crypto" Binding="{Binding Asset}" Width="80" />
                            <DataGridTextColumn Header="Quantite" Binding="{Binding Quantity}" Width="110" />
                            <DataGridTextColumn Header="Contrepartie" Binding="{Binding Quote}" Width="130" />
                            <DataGridTextColumn Header="Prix execution" Binding="{Binding UnitPrice}" Width="125" />
                            <DataGridTextColumn Header="Frais" Binding="{Binding Fee}" Width="110" />
                            <DataGridTextColumn Header="Source" Binding="{Binding SourceKind}" Width="105" />
                            <DataGridTextColumn Header="ID ordre" Binding="{Binding ExternalId}" Width="110" />
                            <DataGridTextColumn Header="Statut" Binding="{Binding Status}" Width="105" />
                            <DataGridTextColumn Header="Motif" Binding="{Binding Reason}" Width="2*" />
                        </DataGrid.Columns>
                    </DataGrid>
                </TabItem>
                <TabItem x:Name="ImportQuarantineTab" Header="Quarantaine">
                    <DataGrid x:Name="QuarantineGrid" AutoGenerateColumns="False" IsReadOnly="True" MinHeight="220"
                              Background="#0F172A" Foreground="#E2E8F0" RowBackground="#111827" AlternatingRowBackground="#172033"
                              BorderBrush="#334155" GridLinesVisibility="None" HeadersVisibility="Column" Margin="0,12,0,0">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Actif" Binding="{Binding Asset}" Width="90" />
                            <DataGridTextColumn Header="Type" Binding="{Binding Kind}" Width="90" />
                            <DataGridTextColumn Header="Doublon" Binding="{Binding DuplicateSource}" Width="140" />
                            <DataGridTextColumn Header="Source gardee" Binding="{Binding KeptSource}" Width="140" />
                            <DataGridTextColumn Header="ID ordre" Binding="{Binding ExternalId}" Width="120" />
                            <DataGridTextColumn Header="Raison" Binding="{Binding Reason}" Width="2*" />
                        </DataGrid.Columns>
                    </DataGrid>
                </TabItem>
            </TabControl>

            <TextBlock x:Name="ImportFeedbackText" Foreground="#FBBF24" Margin="0,10,0,0" TextWrapping="Wrap" />
        </StackPanel>
    </Border>
</UserControl>
