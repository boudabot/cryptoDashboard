<UserControl x:Class="LocalCrypto.App.Views.PositionsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:LocalCrypto.App.Controls">
    <Border x:Name="RootAnchor" Background="#0F172A" BorderBrush="#23314A" BorderThickness="1" CornerRadius="8" Padding="18" Margin="0,0,0,14">
        <StackPanel>
            <Grid Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="Positions" FontSize="22" FontWeight="SemiBold" Foreground="White" />
                    <TextBlock Text="Cartes basees sur le ledger valide. Les devises mixtes sont signalees au lieu d'etre consolidees artificiellement." Foreground="#8FA1BD" Margin="0,3,0,0" />
                </StackPanel>
                <TextBlock x:Name="PositionsEmptyText" Grid.Column="1" Text="Aucune position ledger" Foreground="#64748B" VerticalAlignment="Center" />
            </Grid>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.2*" />
                    <ColumnDefinition Width="18" />
                    <ColumnDefinition Width="0.95*" />
                </Grid.ColumnDefinitions>

                <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="430">
                    <ItemsControl x:Name="PositionCardsItems">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <controls:AssetPositionCard ProofRequested="AssetPositionCard_ProofRequested" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <Border Grid.Column="2" x:Name="AssetXrayPanel" Background="#0B101B" BorderBrush="#263244" BorderThickness="1" CornerRadius="8" Padding="16">
                    <StackPanel>
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock x:Name="AssetXrayTitleText" Text="Asset X-Ray" FontSize="20" FontWeight="SemiBold" Foreground="White" />
                                <TextBlock x:Name="AssetXraySubtitleText" Text="Selectionne un actif pour voir sa preuve ledger." Foreground="#8FA1BD" TextWrapping="Wrap" />
                            </StackPanel>
                            <controls:StatusBadge Grid.Column="1" x:Name="AssetXrayBadge" />
                        </Grid>

                        <TextBlock x:Name="AssetXrayStatusHintText" Foreground="#8FA1BD" TextWrapping="Wrap" Margin="0,0,0,12" />

                        <UniformGrid Columns="2" Margin="0,0,0,14">
                            <Border Background="#111827" CornerRadius="8" Padding="12" Margin="0,0,8,8">
                                <StackPanel>
                                    <TextBlock Text="Quantite" Foreground="#64748B" />
                                    <TextBlock x:Name="AssetXrayQuantityText" Foreground="White" FontWeight="SemiBold" />
                                </StackPanel>
                            </Border>
                            <Border Background="#111827" CornerRadius="8" Padding="12" Margin="0,0,0,8">
                                <StackPanel>
                                    <TextBlock Text="Prix moyen achat" Foreground="#64748B" />
                                    <TextBlock x:Name="AssetXrayAverageText" Foreground="White" FontWeight="SemiBold" />
                                </StackPanel>
                            </Border>
                            <Border Background="#111827" CornerRadius="8" Padding="12" Margin="0,0,8,8">
                                <StackPanel>
                                    <TextBlock Text="Cout suivi" Foreground="#64748B" />
                                    <TextBlock x:Name="AssetXrayCostText" Foreground="White" FontWeight="SemiBold" />
                                </StackPanel>
                            </Border>
                            <Border Background="#111827" CornerRadius="8" Padding="12" Margin="0,0,0,8">
                                <StackPanel>
                                    <TextBlock Text="PnL realise" Foreground="#64748B" />
                                    <TextBlock x:Name="AssetXrayPnlText" Foreground="#22C55E" FontWeight="SemiBold" />
                                </StackPanel>
                            </Border>
                            <Border Background="#111827" CornerRadius="8" Padding="12" Margin="0,0,8,0">
                                <StackPanel>
                                    <TextBlock Text="Frais" Foreground="#64748B" />
                                    <TextBlock x:Name="AssetXrayFeesText" Foreground="White" FontWeight="SemiBold" />
                                </StackPanel>
                            </Border>
                        </UniformGrid>

                        <TextBlock Text="Transactions sources" Foreground="White" FontWeight="SemiBold" Margin="0,0,0,8" />
                        <DataGrid x:Name="AssetTransactionsGrid" AutoGenerateColumns="False" IsReadOnly="True" MinHeight="130" MaxHeight="230"
                                  Background="#0F172A" Foreground="#E2E8F0" RowBackground="#111827" AlternatingRowBackground="#172033"
                                  BorderBrush="#334155" GridLinesVisibility="None" HeadersVisibility="Column">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Date" Binding="{Binding ExecutedAt}" Width="125" />
                                <DataGridTextColumn Header="Side" Binding="{Binding Side}" Width="60" />
                                <DataGridTextColumn Header="Qte" Binding="{Binding Quantity}" Width="*" />
                                <DataGridTextColumn Header="Prix" Binding="{Binding UnitPrice}" Width="*" />
                                <DataGridTextColumn Header="Frais" Binding="{Binding Fee}" Width="*" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </Border>
            </Grid>

            <Border Background="#0B101B" BorderBrush="#263244" BorderThickness="1" CornerRadius="8" Padding="16" Margin="0,16,0,0">
                <StackPanel>
                    <TextBlock Text="Graphiques ledger simples" Foreground="White" FontSize="18" FontWeight="SemiBold" />
                    <TextBlock Text="Vue locale basee uniquement sur les transactions validees. Pas de prix live." Foreground="#8FA1BD" Margin="0,3,0,12" />
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="Cout suivi par devise" Foreground="#CBD5E1" FontWeight="SemiBold" Margin="0,0,0,8" />
                            <ItemsControl x:Name="CostChartItems" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" Margin="16,0,0,0">
                            <TextBlock Text="Volume par actif" Foreground="#CBD5E1" FontWeight="SemiBold" Margin="0,0,0,8" />
                            <ItemsControl x:Name="VolumeChartItems" />
                        </StackPanel>
                        <StackPanel Grid.Column="2" Margin="16,0,0,0">
                            <TextBlock Text="PnL realise par actif" Foreground="#CBD5E1" FontWeight="SemiBold" Margin="0,0,0,8" />
                            <ItemsControl x:Name="PnlChartItems" />
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>
        </StackPanel>
    </Border>
</UserControl>
