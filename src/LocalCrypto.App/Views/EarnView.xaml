<UserControl x:Class="LocalCrypto.App.Views.EarnView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:LocalCrypto.App.Controls">
    <StackPanel x:Name="RootAnchor">
        <Grid Margin="0,0,0,18">
            <StackPanel>
                <TextBlock Text="Earn / Rewards Binance" FontSize="30" FontWeight="SemiBold" Foreground="White" />
                <TextBlock Text="Produits Binance Earn observes via API read-only. Ce n'est pas Import Studio et ce n'est pas le ledger valide." Foreground="#8FA1BD" Margin="0,4,0,0" />
            </StackPanel>
        </Grid>

        <UniformGrid x:Name="EarnMetricsGrid" Columns="3" Margin="0,0,0,16">
            <controls:MetricCard x:Name="EarnProductsCard" Label="Produits Earn" ValueBrush="#38BDF8" />
            <controls:MetricCard x:Name="EarnAssetsCard" Label="Actifs sous-jacents" ValueBrush="#F0B90B" />
            <controls:MetricCard x:Name="EarnStateCard" Label="Statut source" ValueBrush="#FBBF24" />
        </UniformGrid>

        <Border Background="{StaticResource Brush.Card}" BorderBrush="#263A55" BorderThickness="1" CornerRadius="8" Padding="18" Effect="{StaticResource Effect.PanelGlow}">
            <StackPanel>
                <TextBlock Text="Positions Earn observees" Foreground="White" FontSize="20" FontWeight="SemiBold" />
                <TextBlock Text="Les lignes ci-dessous viennent de Binance live/cache. Elles doivent etre rapprochees du ledger avant toute interpretation fiscale ou PnL." Foreground="#8FA1BD" Margin="0,4,0,12" TextWrapping="Wrap" />
                <TextBlock x:Name="EarnEmptyText" Text="Aucune donnee Earn chargee. Va dans Binance API / Compte puis lance un rafraichissement read-only." Foreground="#64748B" Margin="0,0,0,10" TextWrapping="Wrap" />
                <DataGrid x:Name="EarnGrid" AutoGenerateColumns="False" IsReadOnly="True" MinHeight="220">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Source" Binding="{Binding Source}" Width="150" />
                        <DataGridTextColumn Header="Actif" Binding="{Binding Asset}" Width="100" />
                        <DataGridTextColumn Header="Sous-jacent" Binding="{Binding UnderlyingAsset}" Width="120" />
                        <DataGridTextColumn Header="Total" Binding="{Binding Total}" Width="*" />
                        <DataGridTextColumn Header="Prix USDT" Binding="{Binding PriceUsdt}" Width="*" />
                        <DataGridTextColumn Header="Valeur USDT" Binding="{Binding ValueUsdt}" Width="*" />
                        <DataGridTextColumn Header="Statut" Binding="{Binding Status}" Width="1.4*" />
                    </DataGrid.Columns>
                </DataGrid>
            </StackPanel>
        </Border>
    </StackPanel>
</UserControl>
