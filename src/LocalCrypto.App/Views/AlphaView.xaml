<UserControl x:Class="LocalCrypto.App.Views.AlphaView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:LocalCrypto.App.Controls">
    <StackPanel x:Name="RootAnchor">
        <Grid Margin="0,0,0,18">
            <StackPanel>
                <TextBlock Text="Alpha" FontSize="30" FontWeight="SemiBold" Foreground="White" />
                <TextBlock Text="Espace dedie aux actifs Alpha. Rien ici ne doit etre confondu avec Spot tant que la source Alpha n'est pas explicite." Foreground="#8FA1BD" Margin="0,4,0,0" />
            </StackPanel>
        </Grid>

        <UniformGrid Columns="3" Margin="0,0,0,16">
            <controls:MetricCard Label="Source Alpha" Value="Non connectee" Hint="Aucun endpoint Alpha valide dans cette passe." ValueBrush="#FBBF24" />
            <controls:MetricCard Label="Classification" Value="A definir" Hint="Ne pas classer RAVE/OPG/GENIUS en Spot sans preuve." ValueBrush="#38BDF8" />
            <controls:MetricCard Label="Ledger" Value="Separe" Hint="Transactions SQLite restent la verite validee." ValueBrush="#22C55E" />
        </UniformGrid>

        <Border Background="{StaticResource Brush.Card}" BorderBrush="#263A55" BorderThickness="1" CornerRadius="8" Padding="18" Effect="{StaticResource Effect.PanelGlow}">
            <StackPanel>
                <TextBlock Text="Pourquoi cette page existe" Foreground="White" FontSize="20" FontWeight="SemiBold" />
                <TextBlock Text="Alpha et Spot sont deux contextes differents. Cette vue evite de presenter des actifs Alpha comme des positions Spot classiques sans label clair." Foreground="#CBD5E1" TextWrapping="Wrap" Margin="0,8,0,14" />

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="16" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Border Background="#0B1220" BorderBrush="#263244" BorderThickness="1" CornerRadius="8" Padding="14">
                        <StackPanel>
                            <TextBlock Text="Etat actuel" Foreground="#F0B90B" FontWeight="SemiBold" />
                            <TextBlock Text="Aucune data Alpha dediee n'est encore mappee. Les actifs suspects doivent rester visibles avec un label de source ou en reconciliation." Foreground="#E5E7EB" TextWrapping="Wrap" Margin="0,6,0,0" />
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="2" Background="#0B1220" BorderBrush="#263244" BorderThickness="1" CornerRadius="8" Padding="14">
                        <StackPanel>
                            <TextBlock Text="Regle UI" Foreground="#38BDF8" FontWeight="SemiBold" />
                            <TextBlock Text="Quand une source Alpha sera disponible, afficher Alpha live separement du ledger et de Spot. Jamais de consolidation silencieuse." Foreground="#E5E7EB" TextWrapping="Wrap" Margin="0,6,0,0" />
                        </StackPanel>
                    </Border>
                </Grid>
            </StackPanel>
        </Border>
    </StackPanel>
</UserControl>
