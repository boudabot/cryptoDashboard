<UserControl x:Class="LocalCrypto.App.Views.BinanceApiView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:LocalCrypto.App.Controls">
    <StackPanel x:Name="RootAnchor">
        <Grid Margin="0,0,0,18">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock Text="Binance API read-only" FontSize="30" FontWeight="SemiBold" Foreground="White" />
                <TextBlock Text="Source observable Binance: Spot, Earn, ordres ouverts et prix publics. Aucun ordre, aucun transfert, aucune ecriture ledger automatique." Foreground="#8FA1BD" Margin="0,4,0,0" />
            </StackPanel>
            <Border Grid.Column="1" Background="{StaticResource Brush.Card}" BorderBrush="#263A55" BorderThickness="1" CornerRadius="8" Padding="12,8" VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal">
                    <Ellipse x:Name="BinanceStatusDot" Width="8" Height="8" Fill="#64748B" Margin="0,0,8,0" />
                    <TextBlock x:Name="BinanceStatusText" Text="Non connecte" Foreground="#CBD5E1" FontWeight="SemiBold" />
                </StackPanel>
            </Border>
        </Grid>

        <Border Background="{StaticResource Brush.Card}" BorderBrush="#263A55" BorderThickness="1" CornerRadius="8" Padding="18" Margin="0,0,0,14" Effect="{StaticResource Effect.PanelGlow}">
            <StackPanel>
                <TextBlock Text="Identifiants locaux" Foreground="White" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,6" />
                <TextBlock Text="Utilise une cle API Binance lecture seule. Les champs sont vides apres sauvegarde; le secret n'est jamais reaffiche." Foreground="#8FA1BD" TextWrapping="Wrap" Margin="0,0,0,14" />

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.1*" />
                        <ColumnDefinition Width="18" />
                        <ColumnDefinition Width="1.1*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="API key" Foreground="#94A3B8" />
                        <TextBox x:Name="ApiKeyBox" Background="#111827" Foreground="#E5E7EB" BorderBrush="#334155" Padding="9,7" />
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="API secret" Foreground="#94A3B8" />
                        <PasswordBox x:Name="ApiSecretBox" Background="#111827" Foreground="#E5E7EB" BorderBrush="#334155" Padding="9,7" />
                    </StackPanel>
                    <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Bottom" Margin="18,0,0,0">
                        <Button Content="Verifier + enregistrer" Click="SaveCredentials_Click" Background="#F0B90B" Foreground="#111827" BorderBrush="#F0B90B" FontWeight="SemiBold" Padding="14,9" Margin="0,0,8,0" />
                        <Button Content="Test connexion" Click="TestConnection_Click" Background="#1F2937" Foreground="#E5E7EB" BorderBrush="#334155" Padding="14,9" Margin="0,0,8,0" />
                        <Button Content="Effacer" Click="ClearCredentials_Click" Background="#7F1D1D" Foreground="White" BorderBrush="#991B1B" Padding="14,9" />
                    </StackPanel>
                </Grid>

                <TextBlock x:Name="CredentialHintText" Foreground="#8FA1BD" Margin="0,12,0,0" TextWrapping="Wrap" />
            </StackPanel>
        </Border>

        <UniformGrid x:Name="BinanceMetricsGrid" Columns="4" Margin="0,0,0,14">
            <controls:MetricCard x:Name="BinanceConnectionCard" Label="Connexion" ValueBrush="#FBBF24" />
            <controls:MetricCard x:Name="BinanceSpotAssetsCard" Label="Actifs declares" ValueBrush="#38BDF8" />
            <controls:MetricCard x:Name="BinanceApproxValueCard" Label="Estimation consolidee" />
            <controls:MetricCard x:Name="BinanceLastSyncCard" Label="Derniere synchro" />
        </UniformGrid>

        <Border Background="{StaticResource Brush.Card}" BorderBrush="#263A55" BorderThickness="1" CornerRadius="8" Padding="18">
            <StackPanel>
                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="Source Binance observable" Foreground="White" FontSize="20" FontWeight="SemiBold" />
                        <TextBlock Text="Ce que Binance declare maintenant. Donnee separee du ledger SQLite; les prix et ordres ouverts sont indicatifs." Foreground="#8FA1BD" />
                    </StackPanel>
                    <Button Grid.Column="1" Content="Rafraichir Binance" Click="RefreshSpot_Click" Background="#22C55E" Foreground="#07111F" BorderBrush="#22C55E" FontWeight="SemiBold" Padding="14,9" VerticalAlignment="Center" />
                </Grid>

                <DataGrid x:Name="BinanceBalancesGrid" AutoGenerateColumns="False" IsReadOnly="True" MinHeight="260"
                          Background="#0F172A" Foreground="#E2E8F0" RowBackground="#111827" AlternatingRowBackground="#172033"
                          BorderBrush="#334155" GridLinesVisibility="None" HeadersVisibility="Column">
                <DataGrid.Columns>
                        <DataGridTextColumn Header="Source" Binding="{Binding Source}" Width="130" />
                        <DataGridTextColumn Header="Actif" Binding="{Binding Asset}" Width="100" />
                        <DataGridTextColumn Header="Sous-jacent" Binding="{Binding UnderlyingAsset}" Width="110" />
                        <DataGridTextColumn Header="Libre" Binding="{Binding Free}" Width="*" />
                        <DataGridTextColumn Header="Bloque" Binding="{Binding Locked}" Width="*" />
                        <DataGridTextColumn Header="Total" Binding="{Binding Total}" Width="*" />
                        <DataGridTextColumn Header="Prix USDT" Binding="{Binding PriceUsdt}" Width="*" />
                        <DataGridTextColumn Header="Valeur USDT" Binding="{Binding ValueUsdt}" Width="*" />
                        <DataGridTextColumn Header="Statut" Binding="{Binding Status}" Width="1.4*" />
                    </DataGrid.Columns>
                </DataGrid>

                <Grid Margin="0,18,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="Reconciliation ledger / source Binance" Foreground="White" FontSize="18" FontWeight="SemiBold" />
                        <TextBlock x:Name="BinanceComparisonHintText" Text="Compare le ledger valide avec la derniere observation Binance." Foreground="#8FA1BD" />
                    </StackPanel>
                </Grid>

                <DataGrid x:Name="BinanceComparisonGrid" AutoGenerateColumns="False" IsReadOnly="True" MinHeight="120" MaxHeight="240"
                          Background="#0F172A" Foreground="#E2E8F0" RowBackground="#111827" AlternatingRowBackground="#172033"
                          BorderBrush="#334155" GridLinesVisibility="None" HeadersVisibility="Column">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Actif" Binding="{Binding Asset}" Width="120" />
                        <DataGridTextColumn Header="Ledger valide" Binding="{Binding LedgerQuantity}" Width="*" />
                        <DataGridTextColumn Header="Source Binance" Binding="{Binding BinanceQuantity}" Width="*" />
                        <DataGridTextColumn Header="Ecart" Binding="{Binding Difference}" Width="*" />
                        <DataGridTextColumn Header="Statut" Binding="{Binding Status}" Width="*" />
                    </DataGrid.Columns>
                </DataGrid>

                <Grid Margin="0,18,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="Ordres ouverts" Foreground="White" FontSize="18" FontWeight="SemiBold" />
                        <TextBlock Text="Dernier etat observe. Rien n'est place ou annule depuis localCrypto." Foreground="#8FA1BD" />
                    </StackPanel>
                    <TextBlock x:Name="BinanceCacheText" Grid.Column="1" Text="Cache graphes: -" Foreground="#8FA1BD" HorizontalAlignment="Right" VerticalAlignment="Bottom" />
                </Grid>

                <DataGrid x:Name="BinanceOpenOrdersGrid" AutoGenerateColumns="False" IsReadOnly="True" MinHeight="120" MaxHeight="220"
                          Background="#0F172A" Foreground="#E2E8F0" RowBackground="#111827" AlternatingRowBackground="#172033"
                          BorderBrush="#334155" GridLinesVisibility="None" HeadersVisibility="Column">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Symbole" Binding="{Binding Symbol}" Width="*" />
                        <DataGridTextColumn Header="Side" Binding="{Binding Side}" Width="90" />
                        <DataGridTextColumn Header="Type" Binding="{Binding Type}" Width="110" />
                        <DataGridTextColumn Header="Statut" Binding="{Binding Status}" Width="110" />
                        <DataGridTextColumn Header="Prix" Binding="{Binding Price}" Width="*" />
                        <DataGridTextColumn Header="Quantite" Binding="{Binding Quantity}" Width="*" />
                        <DataGridTextColumn Header="Execute" Binding="{Binding Executed}" Width="*" />
                        <DataGridTextColumn Header="Maj" Binding="{Binding UpdatedAt}" Width="120" />
                    </DataGrid.Columns>
                </DataGrid>

                <TextBlock x:Name="BinanceFeedbackText" Foreground="#FBBF24" TextWrapping="Wrap" Margin="0,10,0,0" />
            </StackPanel>
        </Border>
    </StackPanel>
</UserControl>
