<UserControl x:Class="LocalCrypto.App.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:LocalCrypto.App.Controls">
    <StackPanel x:Name="RootAnchor">
        <Grid Margin="0,0,0,18">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock Text="Portefeuille valide SQLite" FontSize="30" FontWeight="SemiBold" Foreground="White" />
                <TextBlock Text="Ces chiffres viennent uniquement du ledger local. Les imports non valides restent separes." Foreground="#8FA1BD" Margin="0,4,0,0" />
            </StackPanel>
            <Border Grid.Column="1" Background="#0F172A" BorderBrush="#23314A" BorderThickness="1" CornerRadius="8" Padding="12,8" VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal">
                    <Ellipse Width="8" Height="8" Fill="#22C55E" Margin="0,0,8,0" />
                    <TextBlock Text="SQLite actif" Foreground="#CBD5E1" FontWeight="SemiBold" />
                </StackPanel>
            </Border>
        </Grid>

        <UniformGrid x:Name="DashboardMetricsGrid" Columns="6" Margin="0,0,0,14">
            <controls:MetricCard x:Name="AssetCountCard" Label="Actifs suivis" />
            <controls:MetricCard x:Name="TransactionCountCard" Label="Transactions" />
            <controls:MetricCard x:Name="TrackedCostCard" Label="Cout suivi" />
            <controls:MetricCard x:Name="RealizedPnlCard" Label="PnL realise" ValueBrush="#22C55E" />
            <controls:MetricCard x:Name="FeesCard" Label="Frais suivis" />
            <controls:MetricCard x:Name="ConfidenceCard" Label="Confiance" ValueBrush="#FBBF24" />
        </UniformGrid>
    </StackPanel>
</UserControl>
