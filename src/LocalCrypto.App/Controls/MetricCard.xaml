<UserControl x:Class="LocalCrypto.App.Controls.MetricCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             MinHeight="78">
    <Border Background="#111827" BorderBrush="#263244" BorderThickness="1" CornerRadius="8" Padding="14" Margin="0,0,10,0">
        <StackPanel>
            <TextBlock Text="{Binding Label, RelativeSource={RelativeSource AncestorType=UserControl}}" Foreground="#8FA1BD" FontSize="12" />
            <TextBlock Text="{Binding Value, RelativeSource={RelativeSource AncestorType=UserControl}}" Foreground="{Binding ValueBrush, RelativeSource={RelativeSource AncestorType=UserControl}}" FontSize="24" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
            <TextBlock Text="{Binding Hint, RelativeSource={RelativeSource AncestorType=UserControl}}" Foreground="#64748B" FontSize="11" TextWrapping="Wrap" />
        </StackPanel>
    </Border>
</UserControl>
