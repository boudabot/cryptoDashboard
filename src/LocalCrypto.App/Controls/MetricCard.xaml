<UserControl x:Class="LocalCrypto.App.Controls.MetricCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             MinHeight="78">
    <Border Background="{StaticResource Brush.Card}" BorderBrush="#263A55" BorderThickness="1" CornerRadius="8" Padding="14" Margin="0,0,10,0">
        <Border.Effect>
            <DropShadowEffect Color="#0EA5E9" BlurRadius="16" ShadowDepth="0" Opacity="0.08" />
        </Border.Effect>
        <Grid>
            <Border Width="3" HorizontalAlignment="Left" Background="#F0B90B" CornerRadius="2" Margin="-14,0,0,0" Opacity="0.85" />
            <StackPanel Margin="4,0,0,0">
            <TextBlock Text="{Binding Label, RelativeSource={RelativeSource AncestorType=UserControl}}" Foreground="#8FA1BD" FontSize="12" />
            <TextBlock Text="{Binding Value, RelativeSource={RelativeSource AncestorType=UserControl}}"
                       Foreground="{Binding ValueBrush, RelativeSource={RelativeSource AncestorType=UserControl}}"
                       FontSize="21"
                       FontWeight="SemiBold"
                       TextWrapping="Wrap" />
            <TextBlock Text="{Binding Hint, RelativeSource={RelativeSource AncestorType=UserControl}}" Foreground="#64748B" FontSize="11" TextWrapping="Wrap" />
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
