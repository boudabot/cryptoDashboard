<UserControl x:Class="LocalCrypto.App.Controls.MetricCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             MinHeight="96">
    <Border Background="{StaticResource Brush.Card}" BorderBrush="#263A55" BorderThickness="1" CornerRadius="8" Padding="14" Margin="0,0,10,10">
        <Border.Effect>
            <DropShadowEffect Color="#0EA5E9" BlurRadius="16" ShadowDepth="0" Opacity="0.08" />
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <Border Height="3" HorizontalAlignment="Stretch" VerticalAlignment="Top" Background="#F0B90B" CornerRadius="2" Opacity="0.85" />
            <StackPanel Grid.Row="1" Margin="0,10,0,0">
                <TextBlock Text="{Binding Label, RelativeSource={RelativeSource AncestorType=UserControl}}"
                           Foreground="#8FA1BD"
                           FontSize="12"
                           TextWrapping="NoWrap" />
                <TextBlock Text="{Binding Value, RelativeSource={RelativeSource AncestorType=UserControl}}"
                           Foreground="{Binding ValueBrush, RelativeSource={RelativeSource AncestorType=UserControl}}"
                           FontSize="18"
                           LineHeight="21"
                           FontWeight="SemiBold"
                           TextWrapping="Wrap" />
                <TextBlock Text="{Binding Hint, RelativeSource={RelativeSource AncestorType=UserControl}}"
                           Foreground="#64748B"
                           FontSize="11"
                           LineHeight="14"
                           TextWrapping="Wrap" />
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
