<UserControl x:Class="LocalCrypto.App.Controls.AssetPositionCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:LocalCrypto.App.Controls">
    <Border Background="{StaticResource Brush.Card}" BorderBrush="#2A3E5E" BorderThickness="1" CornerRadius="8" Padding="16" Margin="0,0,0,12">
        <Border.Effect>
            <DropShadowEffect Color="#38BDF8" BlurRadius="20" ShadowDepth="0" Opacity="0.10" />
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Orientation="Horizontal">
                <controls:AssetLogo Symbol="{Binding Symbol}" Initials="{Binding Logo}" Accent="{Binding Accent}" Diameter="44" InitialFontSize="12" Margin="0,0,12,0" />
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="{Binding Symbol}" Foreground="White" FontSize="16" FontWeight="SemiBold" />
                    <TextBlock Text="{Binding AssetName}" Foreground="#8FA1BD" />
                </StackPanel>
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                <controls:StatusBadge Text="{Binding Confidence}" ToneBrush="{Binding ConfidenceTone}" VerticalAlignment="Center" Margin="0,0,10,0" />
                <Button Content="Voir preuve" Click="Button_Click" Background="#111827" Foreground="#F0B90B" BorderBrush="#3B4F70" FontWeight="SemiBold" Padding="10,6" Cursor="Hand" />
            </StackPanel>

            <WrapPanel Grid.Row="1" Grid.ColumnSpan="2" Margin="56,12,0,0">
                <StackPanel Width="150" Margin="0,0,18,8">
                    <TextBlock Text="Quantite nette" Foreground="#64748B" FontSize="12" />
                    <TextBlock Text="{Binding Quantity}" Foreground="White" FontWeight="SemiBold" TextWrapping="Wrap" />
                </StackPanel>
                <StackPanel Width="185" Margin="0,0,18,8">
                    <TextBlock Text="Cout suivi" Foreground="#64748B" FontSize="12" />
                    <TextBlock Text="{Binding InvestedCost}" Foreground="White" FontWeight="SemiBold" TextWrapping="Wrap" />
                </StackPanel>
                <StackPanel Width="185" Margin="0,0,18,8">
                    <TextBlock Text="Prix moyen achat" Foreground="#64748B" FontSize="12" />
                    <TextBlock Text="{Binding AverageCost}" Foreground="White" FontWeight="SemiBold" TextWrapping="Wrap" />
                </StackPanel>
                <StackPanel Width="185" Margin="0,0,0,8">
                    <TextBlock Text="PnL realise" Foreground="#64748B" FontSize="12" />
                    <TextBlock Text="{Binding RealizedPnl}" Foreground="{Binding RealizedPnlBrush}" FontWeight="SemiBold" TextWrapping="Wrap" />
                    <TextBlock Text="{Binding CurrencyHint}" Foreground="#64748B" FontSize="11" TextWrapping="Wrap" />
                </StackPanel>
            </WrapPanel>
        </Grid>
    </Border>
</UserControl>
