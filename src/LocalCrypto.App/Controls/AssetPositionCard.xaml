<UserControl x:Class="LocalCrypto.App.Controls.AssetPositionCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:LocalCrypto.App.Controls">
    <Border Background="#111827" BorderBrush="#263244" BorderThickness="1" CornerRadius="8" Padding="14" Margin="0,0,0,10">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="54" />
                <ColumnDefinition Width="1.15*" />
                <ColumnDefinition Width="1*" />
                <ColumnDefinition Width="1.05*" />
                <ColumnDefinition Width="1.05*" />
                <ColumnDefinition Width="1.05*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <Border Width="38" Height="38" CornerRadius="19" Background="{Binding Accent}">
                <TextBlock Text="{Binding Logo}" Foreground="#07111F" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" />
            </Border>
            <StackPanel Grid.Column="1">
                <TextBlock Text="{Binding Symbol}" Foreground="White" FontSize="16" FontWeight="SemiBold" />
                <TextBlock Text="{Binding AssetName}" Foreground="#8FA1BD" />
            </StackPanel>
            <StackPanel Grid.Column="2">
                <TextBlock Text="Quantite nette" Foreground="#64748B" FontSize="12" />
                <TextBlock Text="{Binding Quantity}" Foreground="White" FontWeight="SemiBold" />
            </StackPanel>
            <StackPanel Grid.Column="3">
                <TextBlock Text="Cout suivi" Foreground="#64748B" FontSize="12" />
                <TextBlock Text="{Binding InvestedCost}" Foreground="White" FontWeight="SemiBold" />
            </StackPanel>
            <StackPanel Grid.Column="4">
                <TextBlock Text="Prix moyen achat" Foreground="#64748B" FontSize="12" />
                <TextBlock Text="{Binding AverageCost}" Foreground="White" FontWeight="SemiBold" />
            </StackPanel>
            <StackPanel Grid.Column="5">
                <TextBlock Text="PnL realise" Foreground="#64748B" FontSize="12" />
                <TextBlock Text="{Binding RealizedPnl}" Foreground="{Binding RealizedPnlBrush}" FontWeight="SemiBold" />
                <TextBlock Text="{Binding CurrencyHint}" Foreground="#64748B" FontSize="11" />
            </StackPanel>
            <StackPanel Grid.Column="6" HorizontalAlignment="Right">
                <controls:StatusBadge Text="{Binding Confidence}" ToneBrush="{Binding ConfidenceTone}" HorizontalAlignment="Right" Margin="0,0,0,8" />
                <Button Content="Voir preuve" Click="Button_Click" Background="#F0B90B" Foreground="#111827" BorderBrush="#F0B90B" FontWeight="SemiBold" Padding="10,6" Cursor="Hand" />
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
