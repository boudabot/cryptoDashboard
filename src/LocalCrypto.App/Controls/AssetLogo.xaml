<UserControl x:Class="LocalCrypto.App.Controls.AssetLogo"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Width="{Binding Diameter, RelativeSource={RelativeSource AncestorType=UserControl}}"
          Height="{Binding Diameter, RelativeSource={RelativeSource AncestorType=UserControl}}">
        <Ellipse x:Name="GlowRing" Fill="{Binding Accent, RelativeSource={RelativeSource AncestorType=UserControl}}" Opacity="0.22">
            <Ellipse.Effect>
                <DropShadowEffect Color="#38BDF8" BlurRadius="12" ShadowDepth="0" Opacity="0.26" />
            </Ellipse.Effect>
        </Ellipse>

        <Border x:Name="FallbackBadge"
                Margin="2"
                CornerRadius="999"
                Background="{Binding Accent, RelativeSource={RelativeSource AncestorType=UserControl}}">
            <TextBlock x:Name="FallbackText"
                       Text="{Binding Initials, RelativeSource={RelativeSource AncestorType=UserControl}}"
                       Foreground="#07111F"
                       FontWeight="Bold"
                       FontSize="{Binding InitialFontSize, RelativeSource={RelativeSource AncestorType=UserControl}}"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center" />
        </Border>

        <Border x:Name="ImageHost" Visibility="Collapsed" Margin="1" CornerRadius="999" Background="#07111F">
            <Image x:Name="LogoImage" Stretch="Uniform" Margin="1" />
        </Border>
    </Grid>
</UserControl>
