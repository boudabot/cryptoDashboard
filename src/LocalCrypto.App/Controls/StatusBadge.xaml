<UserControl x:Class="LocalCrypto.App.Controls.StatusBadge"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border Background="{Binding ToneBrush, RelativeSource={RelativeSource AncestorType=UserControl}}" CornerRadius="14" Padding="10,5">
        <Border.Effect>
            <DropShadowEffect Color="#F0B90B" BlurRadius="10" ShadowDepth="0" Opacity="0.16" />
        </Border.Effect>
        <TextBlock Text="{Binding Text, RelativeSource={RelativeSource AncestorType=UserControl}}" Foreground="#07111F" FontWeight="SemiBold" FontSize="12" TextWrapping="NoWrap" />
    </Border>
</UserControl>
