<UserControl x:Class="LocalCrypto.App.Controls.StatusBadge"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border Background="{Binding ToneBrush, RelativeSource={RelativeSource AncestorType=UserControl}}" CornerRadius="8" Padding="9,5">
        <TextBlock Text="{Binding Text, RelativeSource={RelativeSource AncestorType=UserControl}}" Foreground="#07111F" FontWeight="SemiBold" FontSize="12" />
    </Border>
</UserControl>
