<UserControl x:Class="LocalCrypto.App.Controls.AssetChip"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Button Click="Button_Click" Background="#182235" BorderBrush="#334155" BorderThickness="1" Padding="10,6" Margin="0,0,8,8" Cursor="Hand">
        <StackPanel Orientation="Horizontal">
            <Border Width="18" Height="18" CornerRadius="9" Background="{Binding Accent}" Margin="0,0,7,0">
                <TextBlock Text="{Binding Asset}" Foreground="#07111F" FontSize="9" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" />
            </Border>
            <TextBlock Text="{Binding Label}" Foreground="#E5E7EB" FontWeight="SemiBold" />
            <TextBlock Text="{Binding Count}" Foreground="#94A3B8" Margin="6,0,0,0" />
        </StackPanel>
    </Button>
</UserControl>
