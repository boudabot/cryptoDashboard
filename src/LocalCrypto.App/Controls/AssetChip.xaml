<UserControl x:Class="LocalCrypto.App.Controls.AssetChip"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:LocalCrypto.App.Controls">
    <Button Click="Button_Click" Background="#111827" BorderBrush="#263A55" BorderThickness="1" Padding="11,7" Margin="0,0,8,8" Cursor="Hand">
        <StackPanel Orientation="Horizontal">
            <controls:AssetLogo Symbol="{Binding Asset}" Initials="{Binding Asset}" Accent="{Binding Accent}" Diameter="20" InitialFontSize="8" Margin="0,0,7,0" />
            <TextBlock Text="{Binding Label}" Foreground="#E5E7EB" FontWeight="SemiBold" />
            <TextBlock Text="{Binding Count}" Foreground="#94A3B8" Margin="6,0,0,0" />
        </StackPanel>
    </Button>
</UserControl>
